# 小程序前端生产环境变量。
# 发布前把占位值改成真实线上地址和模板 ID。

# 小程序展示名称。
VITE_APP_NAME=Life Record

# 线上后端接口域名。
VITE_API_BASE_URL=https://api.your-domain.com

# 线上 OSS 或 CDN 域名。
VITE_OSS_BASE_URL=https://cdn.your-domain.com

# 小程序“日记提醒”订阅消息模板 ID。
VITE_MP_DIARY_TEMPLATE_ID=your-mini-program-diary-template-id

# 小程序“纪念日提醒”订阅消息模板 ID。
VITE_MP_MEMORIAL_TEMPLATE_ID=your-mini-program-memorial-template-id
