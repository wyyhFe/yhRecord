# 小程序前端开发环境变量。
# 这个文件用于本地调试，请按你本机的后端和 OSS 地址修改。

# 小程序展示名称。
VITE_APP_NAME=Life Record

# 本地后端接口地址。
VITE_API_BASE_URL=http://127.0.0.1:8080

# OSS 资源访问基础域名，前端会用它来拼接图片完整地址。
VITE_OSS_BASE_URL=https://wyhosskey.oss-cn-hangzhou.aliyuncs.com

# 小程序“日记提醒”订阅消息模板 ID。
VITE_MP_DIARY_TEMPLATE_ID=

# 小程序“纪念日提醒”订阅消息模板 ID。
VITE_MP_MEMORIAL_TEMPLATE_ID=
